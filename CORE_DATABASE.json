// ==========================================
// NIOS STUDY APP - CORE DATABASE SCHEMA
// ==========================================

// 1. SUBJECT & CHAPTER (The High-Level Containers)
export interface Subject {
  id: string; // e.g., 'cs-12', 'maths-12'
  name: string;
  class_level: 10 | 12;
  total_marks: number;
}

export interface Chapter {
  id: string;
  subject_id: string;
  name: string;
  chapter_number: number;
  expected_weightage: number; // Crucial for "Last Minute" triage. How many marks usually come from here?
  is_active: boolean; // Kill switch if the AI pipeline hallucinates an entire chapter
}

// 2. TOPIC (The Routing & Tracking Engine)
export interface Topic {
  id: string;
  chapter_id: string;
  name: string;
  
  // Goal Tracking Engine
  goal_tier: 'CORE' | 'STANDARD' | 'ADVANCED'; 
  // CORE: High frequency, basic. Must know to pass.
  // STANDARD: Medium frequency. Needed for 75%.
  // ADVANCED: Low frequency, complex. Differentiates 90%+ scorers.
  
  historical_frequency_score: number; // 1-10 scale based on 5+ years of PYQs
  
  // Weakness Tracking Engine (Graph traversal)
  prerequisite_topic_ids: string[]; // If a user fails this topic, route them here first
  related_topic_ids: string[];
}

// 3. CONTENT BLOCK (The Anti-Hallucination & Multimodal Engine)
export interface ContentBlock {
  id: string;
  topic_id: string;
  
  type: 'CONCEPT' | 'FORMULA' | 'DIAGRAM' | 'CODE_SNIPPET' | 'COMMON_MISTAKE';
  
  // The Payload (Can be text, math via LaTeX, or markdown)
  content_text: string | null; 
  
  // The Code Engine (For CS)
  code_content: string | null; // Exact code block, no AI refactoring
  code_language: 'cpp' | 'python' | 'html' | 'sql' | null;
  
  // The Media Engine (For Physics, Bio, CS flowcharts)
  media_url: string | null; // URL to Cloudflare R2 bucket
  media_caption: string | null; 
  
  // --- THE VERIFICATION ENGINE (MANDATORY) ---
  source_pdf_name: string;
  source_page_number: number;
  exact_source_quote: string | null; // Verbatim text proving this isn't an AI hallucination
  is_verified: boolean; // Must be flagged true by Evaluator AI or human before serving to user
}

// 4. PYQ (Past Year Question - The Assessment Layer)
export interface PYQ {
  id: string;
  topic_id: string;
  
  year: number;
  exam_session: 'APRIL' | 'OCTOBER'; // NIOS specific
  marks_awarded: number;
  difficulty: 'EASY' | 'MEDIUM' | 'HARD';
  
  // The Question
  question_text: string; // Must support LaTeX. e.g., "Solve $x^2 + 2x + 1 = 0$"
  question_media_url: string | null; // E.g., "Find current in the circuit diagram below"
  question_code_snippet: string | null; // E.g., "Find the output of this C++ snippet"
  
  // The Solution
  solution_text: string; // Step-by-step. Support block LaTeX for derivations
  solution_media_url: string | null; 
  solution_code_snippet: string | null; 
  
  common_errors_text: string | null; // Tagging where most students fail in this specific PYQ
  is_verified: boolean;
}

// 5. USER PROGRESS (The State Management)
export interface UserProgress {
  user_id: string;
  topic_id: string;
  status: 'NOT_STARTED' | 'REVIEWING' | 'MASTERED' | 'STRUGGLING';
  pyqs_attempted: number;
  pyqs_correct: number;
  last_reviewed_at: Date;
}
