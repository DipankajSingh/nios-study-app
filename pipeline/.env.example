# Pipeline Environment Variables
# Copy this file to .env and fill in your API keys

# DeepSeek API for content structuring (alternative to Gemini)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Claude API for PYQ solving (Stage 05)  
CLAUDE_API_KEY=sk-ant-your-claude-key-here

# Groq API (optional, for faster inference)
GROQ_API_KEY=gsk_your-groq-key-here

# Gemini API for content structuring (Stage 03) - REQUIRED
GEMINI_API_KEY=AIzaSy-your-gemini-key-here

# Kaggle credentials for PDF extraction (Stage 02) - REQUIRED
KAGGLE_API_TOKEN=KGAT_your-kaggle-token-here
KAGGLE_USERNAME=your-kaggle-username