# root .gitignore for NIOS project

# Node modules
/node_modules/
/web/node_modules/
/backend/node_modules/

# Build outputs
/web/dist/

# Environment files
.env
scripts/.env
backend/.env
web/.env

# Wrangler state directories
backend/.wrangler/

# Logs and temporary files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS-specific
.DS_Store
Thumbs.db

# Ignore generated PDF/documentation
*.pdf

# exclude content if you prefer to regenerate (optional)
# content/**

# Sensitive and runtime files in scripts (legacy)
scripts/credentials.json
scripts/token.json
scripts/__pycache__/
scripts/venv/

# Pipeline
pipeline/.env
pipeline/output/
pipeline/**/__pycache__/
pipeline/01_scrape/credentials.json
pipeline/01_scrape/token.json
