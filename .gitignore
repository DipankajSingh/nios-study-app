# root .gitignore for NIOS project

# Node modules
/node_modules/
/web/node_modules/
/backend/node_modules/

# Build outputs
/web/dist/

# Environment files
.env
scripts/.env
backend/.env
web/.env

# Wrangler state directories
backend/.wrangler/

# Logs and temporary files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS-specific
.DS_Store
Thumbs.db

# Ignore generated PDF/documentation
*.pdf

# exclude content if you prefer to regenerate (optional)
# content/**
